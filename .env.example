# ============================================================
# AI CareCompanion — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Firebase credentials are provided natively via:
#   Android → android/app/google-services.json
#   iOS     → ios/GoogleService-Info.plist
# Do NOT put Firebase keys here — they won't be read by
# @react-native-firebase/* packages.
# ============================================================

# ── Gemini API ───────────────────────────────────────────────
# Used for: cloud AI chat, affordable alternatives, place search
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Sign-In ───────────────────────────────────────────
# Web Client ID from Firebase Console → Auth → Sign-in method
# → Google → Web SDK config → Web client ID
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# ── On-Device AI Model ───────────────────────────────────────
# Direct download URL for the Gemma 4 4B GGUF file (~1.5 GB)
# Recommended: Gemma 4 E4B IQ2_M from Hugging Face (Unsloth)
MODEL_DOWNLOAD_URL=https://huggingface.co/your-org/gemma4-4b-iq2_m-gguf/resolve/main/model.gguf
